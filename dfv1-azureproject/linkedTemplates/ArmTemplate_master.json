{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "dfv1-azureproject"
		},
		"AzureSql_vaish_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSql_vaish'"
		},
		"DataLake_vaish_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'DataLake_vaish'"
		},
		"AzureSql_vaish_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "azurev1projectserver.database.windows.net"
		},
		"AzureSql_vaish_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "azureprojectdbvaish"
		},
		"AzureSql_vaish_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminvaish"
		},
		"DataLake_vaish_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storagev1azureproject.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "dfv1-azureproject_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureSql_vaish_password": {
						"value": "[parameters('AzureSql_vaish_password')]"
					},
					"DataLake_vaish_accountKey": {
						"value": "[parameters('DataLake_vaish_accountKey')]"
					},
					"AzureSql_vaish_properties_typeProperties_server": {
						"value": "[parameters('AzureSql_vaish_properties_typeProperties_server')]"
					},
					"AzureSql_vaish_properties_typeProperties_database": {
						"value": "[parameters('AzureSql_vaish_properties_typeProperties_database')]"
					},
					"AzureSql_vaish_properties_typeProperties_userName": {
						"value": "[parameters('AzureSql_vaish_properties_typeProperties_userName')]"
					},
					"DataLake_vaish_properties_typeProperties_url": {
						"value": "[parameters('DataLake_vaish_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}